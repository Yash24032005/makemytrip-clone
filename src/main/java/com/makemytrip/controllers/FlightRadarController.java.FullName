package com.makemytrip.controllers; import com.makemytrip.models.Flight; import com.makemytrip.repositories.FlightRepository; import org.springframework.web.bind.annotation.*; import java.util.List; import java.util.Random; @RestController @RequestMapping("/api/radar") @CrossOrigin(origins = "*") public class FlightRadarController { private final FlightRepository flightRepository; private final String[] statuses = {"On Time", "Delayed by 1h", "Boarding", "In Air", "Arrived"}; public FlightRadarController(FlightRepository flightRepository) { this.flightRepository = flightRepository; } @GetMapping("/live") public List<Flight> getLiveRadar() { List<Flight> flights = flightRepository.findAll(); Random random = new Random(); for (Flight flight : flights) { flight.setStatus(statuses[random.nextInt(statuses.length)]); } return flights; } }
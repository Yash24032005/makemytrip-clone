package com.makemytrip.controllers; import com.makemytrip.models.Review; import com.makemytrip.repositories.ReviewRepository; import org.springframework.web.bind.annotation.*; import java.util.List; @RestController @RequestMapping("/api/reviews") @CrossOrigin(origins = "*") public class ReviewController { private final ReviewRepository reviewRepository; public ReviewController(ReviewRepository reviewRepository) { this.reviewRepository = reviewRepository; } @GetMapping("/{targetId}") public List<Review> getReviews(@PathVariable String targetId, @RequestParam(defaultValue = "newest") String sortBy) { if ("helpful".equals(sortBy)) { return reviewRepository.findByTargetIdAndIsFlaggedFalseOrderByHelpfulCountDesc(targetId); } return reviewRepository.findByTargetIdAndIsFlaggedFalseOrderByCreatedAtDesc(targetId); } @PostMapping public Review createReview(@RequestBody Review review) { return reviewRepository.save(review); } @PostMapping("/{reviewId}/flag") public Review flagReview(@PathVariable String reviewId) { Review review = reviewRepository.findById(reviewId).orElseThrow(() -> new RuntimeException("Review not found")); review.setIsFlagged(true); return reviewRepository.save(review); } }